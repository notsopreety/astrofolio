---
import { ClientRouter } from 'astro:transitions';
import { discordId, footerSocials } from '../config/portfolioData';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const { 
	title = "Samir Badaila | Backend Developer",
	description = "Personal website and blog of Samir Badaila, a backend developer based in Nepal. I build modular APIs, reverse-engineer web protocols, and automate processes.",
	ogImage = "/default-og.png"
} = Astro.props;

const pathname = Astro.url.pathname;
const currentPath = pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const canonicalURL = new URL(pathname, Astro.site || 'https://samirb.com.np').href;
const ogImageURL = new URL(ogImage, Astro.site || 'https://samirb.com.np').href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:site_name" content="samirb.com.np" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={ogImageURL} />

		<!-- Sitemap & RSS Autodiscovery -->
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="alternate" type="application/rss+xml" title="samirb.com.np RSS Feed" href="/rss.xml" />
		
		<!-- Fonts Preloading -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" href="/fonts/MinecraftTen-VGORe.woff" as="font" type="font/woff" crossorigin />
		<!-- Google Fonts Asynchronous Loading -->
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" media="print" onload="this.media='all'" />
		<noscript>
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" />
		</noscript>

		<ClientRouter />
		
		<!-- Theme Initialization to prevent flash of unstyled content -->
		<script is:inline define:vars={{ discordId }}>
			(function () {
				if ('scrollRestoration' in history) {
					history.scrollRestoration = 'manual';
				}
				window.scrollTo(0, 0);

				const stored = localStorage.getItem("theme");
				const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				const theme = stored ?? (prefersDark ? "dark" : "light");
				document.documentElement.setAttribute("data-theme", theme);
				document.documentElement.classList.toggle("dark", theme === "dark");

				if (theme === "dark") {
					const discordAccent = localStorage.getItem("discord-accent");
					if (discordAccent) {
						document.documentElement.style.setProperty("--accent-color", discordAccent);
					}
					// Fetch and cache the latest Discord accent color in the background
					fetch(`https://dcdn.dstn.to/profile/${discordId}`)
						.then(res => res.json())
						.then(data => {
							const color = data?.user?.banner_color;
							if (color) {
								localStorage.setItem("discord-accent", color);
								document.documentElement.style.setProperty("--accent-color", color);
							} else if (!discordAccent) {
								document.documentElement.style.setProperty("--accent-color", "#81c784");
							}
						})
						.catch(() => {
							if (!discordAccent) {
								document.documentElement.style.setProperty("--accent-color", "#81c784");
							}
						});
				}
			})();
		</script>
	</head>
	<body data-discord-id={discordId}>
		<header class="site-header">
			<div class="header-container">
				<a href="/" class="site-logo" transition:name="site-logo">
					samirb.com<span class="logo-accent">.np</span>
				</a>

				<button
					id="menu-btn"
					class="menu-btn"
					aria-label="Open Menu"
					aria-expanded="false"
				>
					<svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="4" y1="12" x2="20" y2="12"></line>
						<line x1="4" y1="6" x2="20" y2="6"></line>
						<line x1="4" y1="18" x2="20" y2="18"></line>
					</svg>
					<svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>

				<nav id="site-nav" class="site-nav">
					<a href="/" class:list={["nav-link", { active: currentPath === "/" }]}>Home</a>
					<a href="/about" class:list={["nav-link", { active: currentPath.startsWith("/about") }]}>About</a>
					<a href="/posts" class:list={["nav-link", { active: currentPath.startsWith("/posts") }]}>Posts</a>
					<a href="/tags" class:list={["nav-link", { active: currentPath.startsWith("/tags") }]}>Tags</a>
					<a href="/message" class:list={["nav-link", { active: currentPath.startsWith("/message") }]}>Message</a>
					
					<!-- Archive Box Icon Link -->
					<a href="/archive" class:list={["nav-link", "archive-icon-link", { active: currentPath.startsWith("/archive") }]} title="Archive" aria-label="Archive">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-archive-icon">
							<path d="M21 8H3V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2z"></path>
							<path d="M10 12h4"></path>
							<path d="M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8"></path>
						</svg>
						<span class="nav-archive-text">Archive</span>
					</a>
					
					<button
						id="theme-btn"
						class="theme-toggle-btn"
						aria-label="Toggle Theme"
						title="Toggle Theme"
					>
						<!-- Sun icon (visible in dark mode) -->
						<svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="4"></circle>
							<path d="M12 2v2"></path>
							<path d="M12 20v2"></path>
							<path d="m4.93 4.93 1.41 1.41"></path>
							<path d="m17.66 17.66 1.41 1.41"></path>
							<path d="M2 12h2"></path>
							<path d="M20 12h2"></path>
							<path d="m6.34 17.66-1.41 1.41"></path>
							<path d="m19.07 4.93-1.41 1.41"></path>
						</svg>
						<!-- Moon icon (visible in light mode) -->
						<svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
						</svg>
					</button>
				</nav>
			</div>
		</header>
		<main class="container">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="footer-container">
				<div class="footer-copyright">
					<span>Copyright © {new Date().getFullYear()}</span>
					<span class="copyright-separator"> | </span>
					<span>All rights reserved.</span>
				</div>
				<div class="footer-socials">
					{footerSocials.map(social => {
						const isExternal = social.platform !== "email";
						return (
							<a href={social.url} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noopener noreferrer" : undefined} title={social.platform.toUpperCase()} aria-label={social.platform}>
								{social.platform === "github" && (
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="footer-social-icon">
										<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
										<path d="M9 18c-4.51 2-5-2-7-2"></path>
									</svg>
								)}
								{social.platform === "x" && (
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="footer-social-icon">
										<path d="M4 4l11.733 16h4.267l-11.733 -16z"></path>
										<path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path>
									</svg>
								)}
								{social.platform === "linkedin" && (
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="footer-social-icon">
										<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
										<rect x="2" y="9" width="4" height="12"></rect>
										<circle cx="4" cy="4" r="2"></circle>
									</svg>
								)}
								{social.platform === "email" && (
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="footer-social-icon">
										<rect width="20" height="16" x="2" y="4" rx="2"></rect>
										<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
									</svg>
								)}
							</a>
						);
					})}
				</div>
			</div>
		</footer>

		<script>
			function applyTheme() {
				const stored = localStorage.getItem("theme");
				const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				const theme = stored ?? (prefersDark ? "dark" : "light");
				
				document.documentElement.setAttribute("data-theme", theme);
				document.documentElement.classList.toggle("dark", theme === "dark");

				if (theme === "dark") {
					const discordId = document.body.getAttribute("data-discord-id") || "931511745284038696";
					const discordAccent = localStorage.getItem("discord-accent") || (window as any).discordAccentColor;
					if (discordAccent) {
						document.documentElement.style.setProperty("--accent-color", discordAccent);
					}
					fetch(`https://dcdn.dstn.to/profile/${discordId}`)
						.then(res => res.json())
						.then(data => {
							const color = data?.user?.banner_color;
							if (color) {
								localStorage.setItem("discord-accent", color);
								document.documentElement.style.setProperty("--accent-color", color);
							} else if (!discordAccent) {
								document.documentElement.style.setProperty("--accent-color", "#81c784");
							}
						})
						.catch(() => {
							if (!discordAccent) {
								document.documentElement.style.setProperty("--accent-color", "#81c784");
							}
						});
				} else {
					document.documentElement.style.removeProperty("--accent-color");
				}
			}

			function setupTheme() {
				const themeBtn = document.getElementById("theme-btn");
				if (!themeBtn) return;

				themeBtn.addEventListener("click", () => {
					const currentTheme = document.documentElement.getAttribute("data-theme") || "dark";
					const newTheme = currentTheme === "light" ? "dark" : "light";
					
					localStorage.setItem("theme", newTheme);
					applyTheme();
				});
			}

			function setupMenuToggle() {
				const menuBtn = document.getElementById("menu-btn");
				const siteNav = document.getElementById("site-nav");
				const menuIcon = document.getElementById("menu-icon");
				const closeIcon = document.getElementById("close-icon");

				if (!menuBtn || !siteNav || !menuIcon || !closeIcon) return;

				// Reset state
				menuBtn.setAttribute("aria-expanded", "false");
				siteNav.classList.remove("open");
				menuIcon.classList.remove("hidden");
				closeIcon.classList.add("hidden");

				menuBtn.addEventListener("click", () => {
					const isExpanded = menuBtn.getAttribute("aria-expanded") === "true";
					menuBtn.setAttribute("aria-expanded", isExpanded ? "false" : "true");
					
					siteNav.classList.toggle("open");
					menuIcon.classList.toggle("hidden");
					closeIcon.classList.toggle("hidden");
				});
			}

			// Force redirect scroll position to top on refresh/load
			if ('scrollRestoration' in history) {
				history.scrollRestoration = 'manual';
			}
			window.scrollTo(0, 0);
			window.addEventListener('load', () => window.scrollTo(0, 0));

			// Initialize
			applyTheme();
			setupTheme();
			setupMenuToggle();

			// Listen for view transitions
			document.addEventListener("astro:after-swap", () => {
				applyTheme();
				setupTheme();
				setupMenuToggle();
				window.scrollTo(0, 0);
			});
		</script>
	</body>
</html>
