---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Prev / Next navigation
const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf()
);
const index = sortedPosts.findIndex((p) => p.id === post.id);
const prevPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
const nextPost = index > 0 ? sortedPosts[index - 1] : null;

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

// Estimate reading time
const wordsPerMinute = 200;
const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / wordsPerMinute));
---

<Layout title={`${post.data.title} | sawmer.dev`}>
  <!-- Reading progress bar -->
  <div class="progress-container" aria-hidden="true">
    <div class="progress-bar" id="reading-progress"></div>
  </div>

  <article class="post-container">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="separator">&raquo;</span>
      <a href="/blog">Posts</a>
      <span class="separator">&raquo;</span>
      <span>{post.data.title}</span>
    </div>

    <button class="back-btn" onclick="history.back()">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Go back
    </button>

    <header class="post-header">
      <h1 class="post-title" transition:name={post.id}>{post.data.title}</h1>
      <div class="post-meta">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        <time datetime={post.data.pubDatetime.toISOString()}>
          {formatDate(post.data.pubDatetime)}
        </time>
        <span class="meta-sep">·</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <span>{readingTime} min read</span>
      </div>

      {post.data.ogImage && (
        <div class="hero-frame-wrapper">
          <div class="hero-frame-accent"></div>
          <img
            src={post.data.ogImage}
            alt={post.data.title}
            class="hero-cover-img"
            loading="eager"
          />
        </div>
      )}
    </header>

    <div class="post-content markdown-body" id="article">
      <Content />
    </div>

    <footer class="post-footer">
      <div class="tags-row">
        <div class="tags-container">
          {post.data.tags && post.data.tags.map((tag) => (
            <span class="tag-badge">#{tag}</span>
          ))}
        </div>
        <button id="back-to-top-btn" class="back-to-top-btn">
          &uarr; Back to top
        </button>
      </div>

      <div class="share-section">
        <span class="share-title">Share this post:</span>
        <div class="share-buttons">
          <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(post.data.title)}%20https://sawmer.dev/blog/${post.id}`} target="_blank" rel="noopener noreferrer" title="Share on WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=https://sawmer.dev/blog/${post.id}`} target="_blank" rel="noopener noreferrer" title="Share on Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=https://sawmer.dev/blog/${post.id}`} target="_blank" rel="noopener noreferrer" title="Share on X">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"></path><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path></svg>
          </a>
          <a href={`https://t.me/share/url?url=https://sawmer.dev/blog/${post.id}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener noreferrer" title="Share on Telegram">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
          </a>
          <a href={`https://pinterest.com/pin/create/button/?url=https://sawmer.dev/blog/${post.id}&description=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener noreferrer" title="Share on Pinterest">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8c-1.6 0-3 1-3 3 0 1.2.6 1.8 1 2 .2 0 .3-.1.4-.3.1-.2.2-.6.2-.8-.1-.2-.4-.6-.4-1.2 0-1.8 1.4-3 3.2-3 1.8 0 3 1.2 3 2.8 0 2-1 3.5-2.5 3.5-.8 0-1.4-.6-1.2-1.3.2-.8.8-1.7.8-2.3 0-.5-.3-.9-.9-.9-.7 0-1.3.7-1.3 1.7 0 .6.2 1 .2 1l-.8 3.4c-.2.8-.1 1.7-.1 1.8 0 .1.1.1.2 0 .1-.1 1.2-1.4 1.6-2.7.2-.6.4-1.6.4-1.6.3.5.9.8 1.6.8 3 0 5-2.5 5-5.8C20 10.2 16.5 8 12 8z"></path></svg>
          </a>
          <a href={`mailto:?subject=${encodeURIComponent(post.data.title)}&body=Check out this post: https://sawmer.dev/blog/${post.id}`} title="Share via Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          </a>
        </div>
      </div>

      <div class="prev-next-section">
        {prevPost && (
          <a href={`/blog/${prevPost.id}`} class="prev-link">
            <span class="nav-label">&larr; Previous Post</span>
            <span class="post-link-title">{prevPost.data.title}</span>
          </a>
        )}
        {!prevPost && <div class="prev-placeholder" />}
        {nextPost && (
          <a href={`/blog/${nextPost.id}`} class="next-link">
            <span class="nav-label">Next Post &rarr;</span>
            <span class="post-link-title">{nextPost.data.title}</span>
          </a>
        )}
      </div>
    </footer>
  </article>
</Layout>

<script>
  // ── Reading progress bar ──────────────────────────────────────
  function setupProgressBar() {
    const bar = document.getElementById("reading-progress");
    if (!bar) return;
    const update = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = docHeight > 0 ? `${(scrollTop / docHeight) * 100}%` : "0%";
    };
    window.addEventListener("scroll", update, { passive: true });
    update();
  }

  // ── Back to top ───────────────────────────────────────────────
  function setupBackToTop() {
    const btn = document.getElementById("back-to-top-btn");
    if (btn) btn.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
  }

  // ── Heading anchor # links ────────────────────────────────────
  function setupHeadingAnchors() {
    const anchors = document.querySelectorAll(".markdown-body .heading-anchor");
    anchors.forEach((a) => {
      (a as HTMLElement).style.opacity = "0";
      const heading = a.parentElement;
      if (!heading) return;
      heading.addEventListener("mouseenter", () => (a as HTMLElement).style.opacity = "1");
      heading.addEventListener("mouseleave", () => (a as HTMLElement).style.opacity = "0");
    });
  }

  // ── Copy code buttons ─────────────────────────────────────────
  function setupCopyButtons() {
    const pres = document.querySelectorAll(".markdown-body pre");
    pres.forEach((pre) => {
      // Avoid adding duplicate buttons
      if (pre.querySelector(".copy-btn")) return;

      const btn = document.createElement("button");
      btn.className = "copy-btn";
      btn.textContent = "Copy";
      btn.setAttribute("aria-label", "Copy code");

      (pre as HTMLElement).style.position = "relative";
      pre.appendChild(btn);

      btn.addEventListener("click", async () => {
        const code = pre.querySelector("code");
        const text = code?.innerText ?? "";
        try {
          await navigator.clipboard.writeText(text);
          btn.textContent = "Copied!";
          btn.classList.add("copied");
          setTimeout(() => {
            btn.textContent = "Copy";
            btn.classList.remove("copied");
          }, 2000);
        } catch {
          btn.textContent = "Failed";
        }
      });
    });
  }

  // ── ToC collapsible details smooth open ──────────────────────
  function setupToc() {
    const details = document.querySelector(".markdown-body details");
    if (details) {
      details.setAttribute("open", "");
    }
  }

  function init() {
    setupProgressBar();
    setupBackToTop();
    setupHeadingAnchors();
    setupCopyButtons();
    setupToc();
  }

  init();
  document.addEventListener("astro:after-swap", init);
</script>

<style>
  /* ── Reading progress bar ── */
  .progress-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    z-index: 999;
    background: transparent;
  }

  .progress-bar {
    height: 100%;
    width: 0%;
    background: var(--accent-color);
    transition: width 0.1s linear;
  }

  /* ── Layout ── */
  .post-container {
    width: 100%;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    cursor: pointer;
    padding: 0.5rem 0;
    margin-bottom: 1.5rem;
    opacity: 0.8;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .back-btn:hover {
    opacity: 1;
    color: var(--accent-color);
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-title {
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    font-weight: 700;
    color: var(--accent-color);
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-family: var(--font-mono);
    margin-bottom: 2rem;
  }

  .meta-sep {
    opacity: 0.4;
  }

  /* ── Hero cover image 3D accent frame ── */
  .hero-frame-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 12px;
    padding-right: 12px;
  }

  .hero-frame-accent {
    position: absolute;
    bottom: 0;
    right: 0;
    width: calc(100% - 8px);
    height: calc(100% - 8px);
    border: 2px solid var(--accent-color);
    border-radius: 4px;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 6px,
        color-mix(in srgb, var(--accent-color) 12%, transparent) 6px,
        color-mix(in srgb, var(--accent-color) 12%, transparent) 7px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 6px,
        color-mix(in srgb, var(--accent-color) 8%, transparent) 6px,
        color-mix(in srgb, var(--accent-color) 8%, transparent) 7px
      );
    pointer-events: none;
  }

  .hero-cover-img {
    position: relative;
    display: block;
    width: 100%;
    height: auto;
    max-height: 420px;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    transform: translate(-6px, -6px);
  }

  /* ═══════════════════════════════════════════
     MARKDOWN BODY — rich prose styles
  ═══════════════════════════════════════════ */
  .markdown-body {
    color: var(--text-primary);
    line-height: 1.8;
    font-size: 1.05rem;
  }

  /* ── Headings ── */
  .markdown-body :global(h1),
  .markdown-body :global(h2),
  .markdown-body :global(h3),
  .markdown-body :global(h4),
  .markdown-body :global(h5),
  .markdown-body :global(h6) {
    color: var(--text-primary);
    font-weight: 700;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    position: relative;
  }

  .markdown-body :global(h1) { font-size: 1.9rem; }
  .markdown-body :global(h2) {
    font-size: 1.5rem;
    border-bottom: 1px dashed var(--card-border);
    padding-bottom: 0.5rem;
  }
  .markdown-body :global(h3) { font-size: 1.25rem; font-style: italic; }
  .markdown-body :global(h4) { font-size: 1.1rem; }

  /* Heading anchor # links (injected by rehype-autolink-headings) */
  .markdown-body :global(.heading-anchor) {
    margin-left: 0.5rem;
    font-weight: 400;
    color: var(--accent-color);
    text-decoration: none;
    font-size: 0.85em;
    opacity: 0;
    transition: opacity 0.15s ease;
    user-select: none;
  }

  .markdown-body :global(h2:hover .heading-anchor),
  .markdown-body :global(h3:hover .heading-anchor),
  .markdown-body :global(h4:hover .heading-anchor) {
    opacity: 1;
  }

  /* ── Paragraphs ── */
  .markdown-body :global(p) {
    margin-bottom: 1.4rem;
  }

  /* ── Inline code `` ── */
  .markdown-body :global(:not(pre) > code) {
    font-family: var(--font-mono);
    background: color-mix(in srgb, var(--accent-color) 12%, var(--bg-primary));
    color: var(--accent-color);
    border: 1px solid color-mix(in srgb, var(--accent-color) 30%, transparent);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.88em;
  }

  /* ── Code blocks ── */
  .markdown-body :global(pre) {
    position: relative;
    border: 1px solid var(--card-border);
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    padding: 1.25rem;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Shiki dual-theme switching */
  .markdown-body :global(.astro-code),
  .markdown-body :global(pre.astro-code) {
    background-color: var(--shiki-light-bg) !important;
    color: var(--shiki-light) !important;
  }

  .markdown-body :global(.astro-code span) {
    color: var(--shiki-light) !important;
  }

  [data-theme="dark"] .markdown-body :global(.astro-code),
  [data-theme="dark"] .markdown-body :global(pre.astro-code) {
    background-color: var(--shiki-dark-bg) !important;
    color: var(--shiki-dark) !important;
  }

  [data-theme="dark"] .markdown-body :global(.astro-code span) {
    color: var(--shiki-dark) !important;
  }

  /* Copy button inside code blocks */
  .markdown-body :global(.copy-btn) {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    z-index: 1;
  }

  .markdown-body :global(.copy-btn:hover) {
    background: color-mix(in srgb, var(--accent-color) 15%, var(--card-bg));
    color: var(--accent-color);
    border-color: var(--accent-color);
  }

  .markdown-body :global(.copy-btn.copied) {
    color: var(--accent-color);
    border-color: var(--accent-color);
  }

  /* ── Blockquotes ── */
  .markdown-body :global(blockquote) {
    border-left: 3px solid var(--accent-color);
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    opacity: 0.85;
    font-style: italic;
  }

  .markdown-body :global(blockquote p) {
    margin: 0;
  }

  /* ── Callout blocks (rehype-callouts): > [!NOTE] etc. ── */
  .markdown-body :global(.callout) {
    border-radius: 6px;
    border: 1px solid var(--card-border);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }

  .markdown-body :global(.callout-title) {
    font-weight: 700;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ── Tables ── */
  .markdown-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.95rem;
    overflow-x: auto;
    display: block;
  }

  .markdown-body :global(thead) {
    background: color-mix(in srgb, var(--accent-color) 10%, var(--card-bg));
  }

  .markdown-body :global(th) {
    font-family: var(--font-mono);
    font-weight: 700;
    text-align: left;
    padding: 0.6rem 1rem;
    border: 1px solid var(--card-border);
    color: var(--accent-color);
  }

  .markdown-body :global(td) {
    padding: 0.55rem 1rem;
    border: 1px solid var(--card-border);
    vertical-align: top;
  }

  .markdown-body :global(tr:nth-child(even) td) {
    background: color-mix(in srgb, var(--accent-color) 4%, transparent);
  }

  /* ── Lists ── */
  .markdown-body :global(ul),
  .markdown-body :global(ol) {
    margin-bottom: 1.4rem;
    padding-left: 1.5rem;
  }

  .markdown-body :global(li) {
    margin-bottom: 0.45rem;
  }

  .markdown-body :global(ul li::marker) {
    color: var(--accent-color);
  }

  .markdown-body :global(ol li::marker) {
    color: var(--accent-color);
    font-family: var(--font-mono);
  }

  /* ── Links ── */
  .markdown-body :global(a:not(.heading-anchor)) {
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 4px;
    text-decoration-color: color-mix(in srgb, var(--accent-color) 50%, transparent);
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .markdown-body :global(a:not(.heading-anchor):hover) {
    color: var(--accent-color);
    text-decoration-color: var(--accent-color);
  }

  /* ── Horizontal rule ── */
  .markdown-body :global(hr) {
    border: none;
    border-top: 1px dashed var(--card-border);
    margin: 2.5rem 0;
  }

  /* ── Strong / em ── */
  .markdown-body :global(strong) {
    font-weight: 700;
    color: var(--text-primary);
  }

  .markdown-body :global(em) {
    font-style: italic;
    opacity: 0.9;
  }

  /* ── Table of Contents (generated by remark-toc + remark-collapse) ── */
  .markdown-body :global(details) {
    border: 1px solid var(--card-border);
    border-radius: 6px;
    padding: 0;
    margin: 1.5rem 0 2rem 0;
    overflow: hidden;
  }

  .markdown-body :global(details > summary) {
    cursor: pointer;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.75rem 1.25rem;
    background: color-mix(in srgb, var(--accent-color) 8%, var(--card-bg));
    color: var(--accent-color);
    list-style: none;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: background 0.2s ease;
  }

  .markdown-body :global(details > summary::before) {
    content: '▶';
    font-size: 0.7rem;
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .markdown-body :global(details[open] > summary::before) {
    transform: rotate(90deg);
  }

  .markdown-body :global(details > summary::-webkit-details-marker) {
    display: none;
  }

  .markdown-body :global(details > summary:hover) {
    background: color-mix(in srgb, var(--accent-color) 14%, var(--card-bg));
  }

  .markdown-body :global(details > ul),
  .markdown-body :global(details > ol) {
    padding: 0.75rem 1.25rem 0.75rem 2.5rem;
    margin: 0;
