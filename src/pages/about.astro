---
import Layout from '../layouts/Layout.astro';
import LanyardCard from '../components/LanyardCard.astro';
import { journeyData, educationData, personalInfo } from '../config/aboutData';

const birthday = new Date(personalInfo.birthdate);
const ageDifMs = Date.now() - birthday.getTime();
const ageDate = new Date(ageDifMs);
const age = Math.abs(ageDate.getUTCFullYear() - 1970);

function getOrdinalSuffix(day: number) {
  if (day > 3 && day < 21) return 'th';
  switch (day % 10) {
    case 1:  return "st";
    case 2:  return "nd";
    case 3:  return "rd";
    default: return "th";
  }
}
const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const birthDay = birthday.getDate();
const monthName = months[birthday.getMonth()];
const yearBirth = birthday.getFullYear();
const formattedBirthdate = `${birthDay}${getOrdinalSuffix(birthDay)} ${monthName} ${yearBirth}`;

function getBirthdayStatus(birthdateStr: string): { show: boolean; text: string } {
  const bday = new Date(birthdateStr);
  const today = new Date();
  
  const currentYearBday = new Date(today.getFullYear(), bday.getMonth(), bday.getDate());
  today.setHours(0, 0, 0, 0);
  currentYearBday.setHours(0, 0, 0, 0);
  
  const oneDayMs = 1000 * 60 * 60 * 24;
  
  // Check if today is the birthday
  if (today.getTime() === currentYearBday.getTime()) {
    return { show: true, text: "Today! 🎉" };
  }
  
  // Check if it's AFTER the birthday of this year (within 7 days after)
  const diffTimeSinceBday = today.getTime() - currentYearBday.getTime();
  const diffDaysSinceBday = Math.round(diffTimeSinceBday / oneDayMs);
  
  if (diffDaysSinceBday > 0 && diffDaysSinceBday <= 7) {
    return { show: true, text: `${diffDaysSinceBday} ${diffDaysSinceBday === 1 ? 'day' : 'days'} ago` };
  }
  
  // Otherwise, calculate countdown to next birthday
  let targetBday = currentYearBday;
  if (today.getTime() > currentYearBday.getTime()) {
    targetBday = new Date(today.getFullYear() + 1, bday.getMonth(), bday.getDate());
    targetBday.setHours(0, 0, 0, 0);
  }
  
  const diffTimeToBday = targetBday.getTime() - today.getTime();
  const diffDaysToBday = Math.round(diffTimeToBday / oneDayMs);
  
  // Only show if the birthday is in 50 days or less
  if (diffDaysToBday <= 50) {
    return { show: true, text: `${diffDaysToBday} days` };
  }
  
  return { show: false, text: "" };
}

const birthdayStatus = getBirthdayStatus(personalInfo.birthdate);

const rootNode = educationData.find(node => node.id === 'highschool');
const leftNode = educationData.find(node => node.id === 'selftaught');
const rightNode = educationData.find(node => node.id === 'bachelors');
---

<Layout title="About Me | Samir Badaila" description="Learn more about Samir Badaila, a backend-focused developer from Kathmandu, Nepal. View his timeline, education, and development journey.">
  <div class="about-page-container">
    <div class="about-top-grid">
      <div class="bio-and-info">
        <section class="about-section">
          <fieldset class="about-fieldset">
            <legend class="about-legend">About Me</legend>
            
            <div class="bio-text">
              <p>
                {personalInfo.bio}
              </p>
            </div>

            <!-- Personal Info Card -->
            <div class="info-card">
              <h3 class="info-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                Personal Info
              </h3>
              <ul class="info-list">
                <li><span class="info-label">Name:</span> <span class="highlight">{personalInfo.name}</span></li>
                <li><span class="info-label">Born:</span> <span>{formattedBirthdate} ({age} Y/O)</span></li>
                <li><span class="info-label">Location:</span> <span>{personalInfo.location}</span></li>
                <li><span class="info-label">Email:</span> <a href={`mailto:${personalInfo.email}`} class="info-link">{personalInfo.email}</a></li>
              </ul>
            </div>

            {birthdayStatus.show && (
              <div class="birthday-countdown-bar">
                <span class="countdown-label">
                  {birthdayStatus.text.includes('ago') ? 'Birthday was:' : birthdayStatus.text.includes('Today') ? 'Birthday is:' : 'Birthday in:'}
                </span>
                <span class="countdown-value">{birthdayStatus.text}</span>
              </div>
            )}
          </fieldset>
        </section>
      </div>
      
      <div class="sidebar">
        <div class="sticky-sidebar">
          <LanyardCard />
        </div>
      </div>
    </div>

    <div class="about-bottom-full">
      <!-- Education Section -->
      <section class="education-section">
        <fieldset class="about-fieldset">
          <legend class="about-legend">Education Path</legend>
          
          <div class="edu-tree">
            <!-- Root node (High School) -->
            {rootNode && (
              <div class="tree-root">
                <div class={`education-card ${rootNode.status}`}>
                  <span class="edu-card-icon">{rootNode.icon}</span>
                  <div class="edu-header">
                    <span class="edu-badge">{rootNode.label}</span>
                    <span class="edu-duration">{rootNode.year ? `${rootNode.year} • ` : ""}{rootNode.status}</span>
                  </div>
                  <h3 class="edu-title">{rootNode.title}</h3>
                  {rootNode.subtitle && <p class="edu-faculty">{rootNode.subtitle}</p>}
                  <p class="edu-desc">{rootNode.desc}</p>
                </div>
              </div>
            )}

            <!-- Connection lines (Pure CSS connectors, perfectly aligned and non-stretching) -->
            <div class="tree-connectors" aria-hidden="true">
              <div class="connector-stem"></div>
              <div class="connector-bar">
                <div class="connector-branch left-branch-line"></div>
                <div class="connector-branch right-branch-line"></div>
              </div>
            </div>

            <!-- Branch column grid containing left/right nodes -->
            <div class="tree-branches">
              <!-- Left Branch (Self-Taught / Specialized) -->
              {leftNode && (
                <div class="tree-branch-col left-branch">
                  <div class={`education-card ${leftNode.status}`}>
                    <span class="edu-card-icon">{leftNode.icon}</span>
                    <div class="edu-header">
                      <span class="edu-badge">{leftNode.label}</span>
                      <span class="edu-duration">{leftNode.year ? `${leftNode.year} • ` : ""}{leftNode.status}</span>
                    </div>
                    <h3 class="edu-title">{leftNode.title}</h3>
                    {leftNode.subtitle && <p class="edu-faculty">{leftNode.subtitle}</p>}
                    <p class="edu-desc">{leftNode.desc}</p>
                  </div>
                </div>
              )}

              <!-- Right Branch (Bachelor's / Advanced) -->
              {rightNode && (
                <div class="tree-branch-col right-branch">
                  <div class={`education-card ${rightNode.status}`}>
                    <span class="edu-card-icon">{rightNode.icon}</span>
                    <div class="edu-header">
                      <span class="edu-badge">{rightNode.label}</span>
                      <span class="edu-duration">{rightNode.year ? `${rightNode.year} • ` : ""}{rightNode.status}</span>
                    </div>
                    <h3 class="edu-title">{rightNode.title}</h3>
                    {rightNode.subtitle && <p class="edu-faculty">{rightNode.subtitle}</p>}
                    <p class="edu-desc">{rightNode.desc}</p>
                  </div>
                </div>
              )}
            </div>
          </div>
        </fieldset>
      </section>

      <!-- Journey Timeline Section -->
      <section class="journey-section">
        <fieldset class="about-fieldset">
          <legend class="about-legend">My Journey</legend>
          
          <div class="timeline-container">
            <div class="timeline-line"></div>
            
            <div class="timeline-items">
              {journeyData.map((item) => (
                <div class="timeline-item">
                  <div class="timeline-badge-container">
                    <div class="timeline-dot"></div>
                    <span class="timeline-icon-box">{item.icon}</span>
                  </div>
                  <div class="timeline-content-card">
                    <div class="timeline-header">
                      <span class={`timeline-type-badge ${item.type}`}>{item.type}</span>
                      <span class="timeline-year">{item.year}</span>
                    </div>
                    <h3 class="timeline-item-title">{item.title}</h3>
                    <p class="timeline-item-desc">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </fieldset>
      </section>
    </div>
  </div>
</Layout>

<style>
  .about-page-container {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    width: 100%;
  }

  .about-top-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
    width: 100%;
  }

  .bio-and-info {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .about-bottom-full {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    width: 100%;
  }

  .sidebar {
    position: relative;
  }

  .sticky-sidebar {
    position: sticky;
    top: 3rem;
  }

  /* Outlined Fieldset Styles */
  .about-fieldset {
    background: transparent;
    border: 1.5px solid var(--accent-color);
    border-radius: 16px;
    padding: 1.5rem;
    margin: 0;
    min-inline-size: 0;
    box-sizing: border-box;
  }

  .about-legend {
    font-size: 0.72rem;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--accent-color);
    letter-spacing: 0.08em;
    font-family: var(--font-minecraft);
    padding: 0 0.5rem;
    margin-left: 0.5rem;
    width: auto;
    line-height: 1;
  }

  .bio-text p {
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text-primary);
    margin: 0 0 1.5rem 0;
  }

  /* Education Cards */
  /* Education Tree Styles */
  .edu-tree {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    margin-top: 1rem;
  }

  .tree-root {
    width: 100%;
    max-width: 480px;
    z-index: 2;
  }

  .tree-connectors {
    width: 100%;
    height: 40px;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .connector-stem {
    width: 2px;
    height: 20px;
    background: var(--accent-color);
  }

  .connector-bar {
    position: absolute;
    top: 20px;
    left: 25%;
    right: 25%;
    height: 2px;
    background: var(--accent-color);
  }

  .connector-branch {
    position: absolute;
    top: 0;
    width: 2px;
    height: 20px;
  }

  .connector-branch.left-branch-line {
    left: 0;
    background: var(--accent-color);
  }

  .connector-branch.right-branch-line {
    right: 0;
    border-left: 2px dashed var(--text-muted);
  }

  .tree-branches {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    width: 100%;
    align-items: start;
  }

  .tree-branch-col {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .education-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .edu-card-icon {
    position: absolute;
    top: -12px;
    right: -12px;
    background: var(--bg-color);
    border: 2px solid var(--accent-color);
    border-radius: 50%;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    z-index: 10;
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.15);
    pointer-events: none;
  }

  .education-card.completed .edu-card-icon {
    border-color: var(--accent-color);
  }

  .education-card.ongoing .edu-card-icon {
    border-color: #60a5fa;
  }

  .education-card.upcoming .edu-card-icon {
    border-color: var(--text-muted);
  }

  .education-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
  }

  .education-card.completed {
    border-color: var(--accent-color);
  }

  .education-card.completed:hover {
    background: linear-gradient(145deg, var(--card-bg), rgba(129, 199, 132, 0.02));
  }

  .education-card.ongoing {
    border-color: #60a5fa;
    box-shadow: 0 0 10px rgba(96, 165, 250, 0.08);
  }

  .education-card.ongoing:hover {
    background: linear-gradient(145deg, var(--card-bg), rgba(96, 165, 250, 0.02));
  }

  .education-card.ongoing .edu-badge {
    background: rgba(96, 165, 250, 0.1);
    color: #60a5fa;
    border-color: #60a5fa;
  }

  .education-card.upcoming {
    border-style: dashed;
    border-color: var(--text-muted);
    opacity: 0.8;
  }

  .education-card.upcoming:hover {
    background: linear-gradient(145deg, var(--card-bg), rgba(143, 143, 158, 0.02));
  }

  .education-card.upcoming .edu-badge {
    background: rgba(143, 143, 158, 0.1);
    color: var(--text-muted);
    border-color: var(--text-muted);
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    margin-bottom: 0.25rem;
  }

  .edu-badge {
    background: rgba(168, 185, 204, 0.1);
    color: var(--accent-color);
    border: 1.5px solid var(--accent-color);
    font-family: var(--font-minecraft);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .education-card.future .edu-badge {
    background: rgba(156, 163, 175, 0.1);
    color: var(--text-secondary);
    border-color: var(--text-secondary);
  }

  .edu-duration {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .edu-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .edu-faculty {
    font-size: 0.88rem;
    color: var(--accent-color);
    font-weight: 500;
    margin: 0;
  }

  .edu-desc {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
  }

  .info-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .info-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-color);
    font-family: var(--font-minecraft);
    text-transform: uppercase;
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card-icon {
    color: var(--accent-color);
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.92rem;
  }

  .info-list li {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .info-label {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .highlight {
    color: var(--accent-color);
    font-weight: 600;
  }

  .info-link {
    color: var(--accent-color);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .info-link:hover {
    opacity: 0.85;
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 6px;
  }

  /* Timeline / Journey styles */
  .timeline-container {
    position: relative;
    padding-left: 2rem;
    margin-top: 0.5rem;
  }

  .timeline-line {
    position: absolute;
    left: 7px;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: var(--card-border);
  }

  .timeline-items {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-item {
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -25px;
    top: 16px;
    width: 26px;
    height: 18px;
    border-bottom: 2px dotted var(--card-border);
    border-left: 2px dotted var(--card-border);
    border-bottom-left-radius: 8px;
    z-index: 1;
    pointer-events: none;
  }

  .timeline-badge-container {
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    display: flex;
    align-items: center;
  }

  .timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg-color);
    border: 3px solid var(--accent-color);
    z-index: 2;
    box-shadow: 0 0 0 3px rgba(129, 199, 132, 0.15), 0 0 10px rgba(129, 199, 132, 0.4);
  }

  .timeline-icon-box {
    display: none; /* Can be enabled for large screen badges */
  }

  .timeline-content-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .timeline-content-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    background: linear-gradient(145deg, var(--card-bg), rgba(129, 199, 132, 0.02));
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.6rem;
  }

  .timeline-year {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-color);
    font-family: var(--font-minecraft);
  }

  .timeline-type-badge {
    font-size: 0.68rem;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .timeline-type-badge.education {
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .timeline-type-badge.project {
    background: rgba(147, 51, 234, 0.15);
    color: #c084fc;
    border: 1px solid rgba(147, 51, 234, 0.3);
  }

  .timeline-type-badge.work {
    background: rgba(16, 185, 129, 0.15);
    color: #34d399;
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .timeline-type-badge.achievement {
    background: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .timeline-item-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.5rem 0;
  }

  .timeline-item-desc {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Responsive styling */
  @media (max-width: 900px) {
    .about-top-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .sidebar {
      order: -1; /* Sidebar with Lanyard Card moves to top on mobile */
    }
  }

  @media (max-width: 768px) {
    .tree-connectors {
      display: none;
    }

    .tree-branches {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .edu-tree {
      position: relative;
      align-items: stretch;
      padding-left: 1.5rem;
    }

    .edu-tree::before {
      content: '';
      position: absolute;
      left: 10px;
      top: 2rem;
      bottom: 2rem;
      width: 2px;
      background: var(--card-border);
      z-index: 1;
    }

    .education-card {
      position: relative;
    }

    .education-card::before {
      content: '';
      position: absolute;
      left: -20px;
      top: 2rem;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--bg-color);
      border: 2px solid var(--accent-color);
      z-index: 2;
    }

    .education-card.ongoing::before {
      border-color: #60a5fa;
    }

    .education-card.upcoming::before {
      border-color: var(--text-muted);
    }

    .info-list li {
      flex-direction: column;
      gap: 0.2rem;
    }
  }

  /* Birthday Countdown Bar styling */
  .birthday-countdown-bar {
    margin-top: 1.25rem;
    padding: 0.75rem 1.25rem;
    background: rgba(129, 199, 132, 0.04);
    border: 1px dashed var(--accent-color);
    border-radius: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.92rem;
  }

  .countdown-label {
    font-family: var(--font-minecraft);
    text-transform: uppercase;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
  }

  .countdown-value {
    color: var(--accent-color);
    font-weight: 700;
  }
</style>
