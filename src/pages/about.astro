---
import Layout from '../layouts/Layout.astro';
import LanyardCard from '../components/LanyardCard.astro';
import { personalInfo, educationList, journeyList } from '../config/about';

const birthday = new Date(personalInfo.birthdate);
const ageDifMs = Date.now() - birthday.getTime();
const ageDate = new Date(ageDifMs);
const age = Math.abs(ageDate.getUTCFullYear() - 1970);
---

<Layout title="About Me | Samir Badaila" description="Learn more about Samir Badaila, a backend-focused developer from Kathmandu, Nepal. View his interactive canvas graph tree, education, and development journey.">
  <div class="landing-grid">
    <div class="main-content">
      <!-- Bio Section -->
      <section class="about-section">
        <fieldset class="about-fieldset">
          <legend class="about-legend">About Me</legend>
          
          <div class="bio-text">
            <p>{personalInfo.bio}</p>
          </div>

          <!-- Personal Info Card -->
          <div class="info-card">
            <h3 class="info-card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              Personal Info
            </h3>
            <ul class="info-list">
              <li><span class="info-label">Name:</span> <span class="highlight">{personalInfo.name}</span></li>
              <li><span class="info-label">Age:</span> <span>{age} years old</span></li>
              <li><span class="info-label">Location:</span> <span>{personalInfo.location}</span></li>
              <li><span class="info-label">Email:</span> <a href={`mailto:${personalInfo.email}`} class="info-link">{personalInfo.email}</a></li>
            </ul>
          </div>
        </fieldset>
      </section>

      <!-- Graph Tree Visualization -->
      <section class="graph-section">
        <fieldset class="about-fieldset">
          <legend class="about-legend">Interactive Map</legend>
          <p class="section-instruction">Hover over the nodes below to trace the connected path of my education and journey details.</p>
          <div class="canvas-container">
            <canvas id="graph-canvas"></canvas>
          </div>
        </fieldset>
      </section>

      <!-- Detailed Info Section -->
      <section class="education-section">
        <fieldset class="about-fieldset">
          <legend class="about-legend">Education & Milestone Details</legend>
          
          <div class="cards-list">
            <!-- Education Cards -->
            {educationList.map(edu => (
              <div class={`detail-card ${edu.status}`} id={`detail-${edu.id}`}>
                <div class="card-header-bar">
                  <span class="badge edu-badge">Education</span>
                  <span class="badge status-badge">{edu.duration}</span>
                </div>
                <h3 class="card-heading">{edu.degree}</h3>
                {edu.faculty && <p class="card-subheading">{edu.faculty}</p>}
                <p class="card-desc">{edu.description}</p>
                {edu.skills && (
                  <div class="skills-tag-list">
                    {edu.skills.map(skill => (
                      <span class="skill-tag">{skill}</span>
                    ))}
                  </div>
                )}
              </div>
            ))}

            <!-- Journey Cards -->
            {journeyList.map(item => (
              <div class="detail-card journey-item" id={`detail-${item.id}`}>
                <div class="card-header-bar">
                  <span class={`badge type-badge ${item.type}`}>{item.type}</span>
                  <span class="badge year-badge">{item.year}</span>
                </div>
                <h3 class="card-heading">
                  <span class="heading-icon">{item.icon}</span>
                  {item.title}
                </h3>
                <p class="card-desc">{item.description}</p>
              </div>
            ))}
          </div>
        </fieldset>
      </section>
    </div>
    
    <div class="sidebar">
      <div class="sticky-sidebar">
        <LanyardCard />
      </div>
    </div>
  </div>
</Layout>

<script>
  function initGraph() {
    const canvas = document.getElementById('graph-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = 0;
    let height = 0;

    // Define tree layout nodes
    const nodes = [
      { id: "journey-started", label: "2020", title: "Start", type: "root", xPct: 0.08, yPct: 0.5, icon: "📖" },
      { id: "edu-highschool", label: "2022", title: "+2 CS", type: "education", xPct: 0.32, yPct: 0.25, icon: "🏫" },
      { id: "journey-react", label: "2021", title: "React", type: "journey", xPct: 0.24, yPct: 0.75, icon: "⚛️" },
      { id: "journey-node", label: "2021", title: "NodeJS", type: "journey", xPct: 0.40, yPct: 0.75, icon: "💻" },
      { id: "journey-freelance", label: "2022", title: "Freelance", type: "journey", xPct: 0.56, yPct: 0.75, icon: "💼" },
      { id: "journey-mongodb", label: "2022", title: "MongoDB", type: "journey", xPct: 0.50, yPct: 0.50, icon: "🏆" },
      { id: "journey-ecommerce", label: "2023", title: "Shop API", type: "journey", xPct: 0.66, yPct: 0.50, icon: "🛒" },
      { id: "journey-startup", label: "2023", title: "Startup", type: "journey", xPct: 0.72, yPct: 0.75, icon: "🚀" },
      { id: "edu-bachelors", label: "Upcoming", title: "BSc IT", type: "education", xPct: 0.76, yPct: 0.25, icon: "🎓" },
      { id: "journey-present", label: "Present", title: "Growth", type: "journey", xPct: 0.92, yPct: 0.5, icon: "📈" }
    ];

    // Connection mapping representing graph tree architecture
    const connections = [
      { from: "journey-started", to: "edu-highschool" },
      { from: "journey-started", to: "journey-react" },
      { from: "journey-react", to: "journey-node" },
      { from: "journey-node", to: "journey-freelance" },
      { from: "journey-freelance", to: "journey-mongodb" },
      { from: "edu-highschool", to: "edu-bachelors" },
      { from: "edu-highschool", to: "journey-mongodb" },
      { from: "journey-mongodb", to: "journey-ecommerce" },
      { from: "journey-ecommerce", to: "edu-bachelors" },
      { from: "journey-ecommerce", to: "journey-startup" },
      { from: "edu-bachelors", to: "journey-present" },
      { from: "journey-startup", to: "journey-present" }
    ];

    let hoverNodeId: string | null = null;
    let scale = window.devicePixelRatio || 1;

    function resize() {
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = width * scale;
      canvas.height = height * scale;
      ctx!.scale(scale, scale);
    }

    window.addEventListener('resize', () => {
      resize();
      draw();
    });

    // Detect mouse move / node selection
    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      const mouseX = e.clientX - rect.left;
      const mouseY = e.clientY - rect.top;

      let found: string | null = null;
      for (const node of nodes) {
        const x = node.xPct * width;
        const y = node.yPct * height;
        const dist = Math.hypot(mouseX - x, mouseY - y);
        if (dist < 20) {
          found = node.id;
          break;
        }
      }

      if (found !== hoverNodeId) {
        hoverNodeId = found;
        draw();
        
        // Highlight active DOM card info details
        if (found) {
          const card = document.getElementById(`detail-${found}`);
          if (card) {
            card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            card.classList.add('highlight-card');
            setTimeout(() => card.classList.remove('highlight-card'), 1500);
          }
        }
      }
    });

    function draw() {
      ctx!.clearRect(0, 0, width, height);

      // Color scheme tokens parsed dynamically from CSS variables
      const bodyStyle = getComputedStyle(document.body);
      const accentColor = bodyStyle.getPropertyValue('--accent-color').trim() || '#81c784';
      const textColor = bodyStyle.getPropertyValue('--text-primary').trim() || '#e3e2e6';
      const textSecondary = bodyStyle.getPropertyValue('--text-secondary').trim() || '#c7c5d0';
      const cardBorder = bodyStyle.getPropertyValue('--card-border').trim() || 'rgba(255,255,255,0.06)';

      // 1. Draw connections
      connections.forEach(conn => {
        const fromNode = nodes.find(n => n.id === conn.from);
        const toNode = nodes.find(n => n.id === conn.to);
        if (!fromNode || !toNode) return;

        const x1 = fromNode.xPct * width;
        const y1 = fromNode.yPct * height;
        const x2 = toNode.xPct * width;
        const y2 = toNode.yPct * height;

        const isHighlighted = hoverNodeId === conn.from || hoverNodeId === conn.to;

        ctx!.beginPath();
        ctx!.moveTo(x1, y1);
        
        // Beautiful curve coordinates
        const cpX1 = x1 + (x2 - x1) / 2;
        const cpY1 = y1;
        const cpX2 = x1 + (x2 - x1) / 2;
        const cpY2 = y2;
        ctx!.bezierCurveTo(cpX1, cpY1, cpX2, cpY2, x2, y2);

        ctx!.strokeStyle = isHighlighted ? accentColor : cardBorder;
        ctx!.lineWidth = isHighlighted ? 3 : 1.5;
        if (!isHighlighted) {
          ctx!.setLineDash([4, 4]);
        } else {
          ctx!.setLineDash([]);
        }
        ctx!.stroke();
        ctx!.setLineDash([]);
      });

      // 2. Draw nodes
      nodes.forEach(node => {
        const x = node.xPct * width;
        const y = node.yPct * height;
        const isHovered = hoverNodeId === node.id;

        // Pulse glow under node
        if (isHovered || node.id === 'journey-present') {
          ctx!.beginPath();
          ctx!.arc(x, y, 20, 0, Math.PI * 2);
          ctx!.fillStyle = accentColor.includes('#') ? `${accentColor}25` : 'rgba(129,199,132,0.15)';
          ctx!.fill();
        }

        ctx!.beginPath();
        ctx!.arc(x, y, 14, 0, Math.PI * 2);
        ctx!.fillStyle = isHovered ? accentColor : '#1d1e24';
        ctx!.strokeStyle = accentColor;
        ctx!.lineWidth = 2;
        ctx!.fill();
        ctx!.stroke();

        // Node glyph
        ctx!.font = '12px sans-serif';
        ctx!.textAlign = 'center';
        ctx!.textBaseline = 'middle';
        ctx!.fillText(node.icon, x, y);

        // Titles
        ctx!.font = '9px monospace';
        ctx!.fillStyle = isHovered ? accentColor : textSecondary;
        ctx!.fillText(node.label, x, y + 25);
        ctx!.font = 'bold 10px sans-serif';
        ctx!.fillStyle = isHovered ? accentColor : textColor;
        ctx!.fillText(node.title, x, y - 22);
      });
    }

    resize();
    draw();

    // Re-render when theme transitions
    const observer = new MutationObserver(() => {
      draw();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'data-theme'] });
  }

  document.addEventListener('astro:page-load', () => {
    initGraph();
  });
</script>

<style>
  .landing-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .main-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .sidebar {
    position: relative;
  }

  .sticky-sidebar {
    position: sticky;
    top: 3rem;
  }

  /* Outlined Fieldset Styles */
  .about-fieldset {
    background: transparent;
    border: 1.5px solid var(--accent-color);
    border-radius: 16px;
    padding: 1.5rem;
    margin: 0;
    min-inline-size: 0;
    box-sizing: border-box;
  }

  .about-legend {
    font-size: 0.72rem;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--accent-color);
    letter-spacing: 0.08em;
    font-family: var(--font-minecraft);
    padding: 0 0.5rem;
    margin-left: 0.5rem;
    width: auto;
    line-height: 1;
  }

  .bio-text p {
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text-primary);
    margin: 0 0 1.5rem 0;
  }

  .info-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .info-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    background: linear-gradient(145deg, var(--card-bg), rgba(129, 199, 132, 0.02));
  }

  .info-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-color);
    font-family: var(--font-minecraft);
    text-transform: uppercase;
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card-icon {
    color: var(--accent-color);
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.92rem;
  }

  .info-list li {
    display: flex;
    justify-content: space-between;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .info-label {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .highlight {
    color: var(--accent-color);
    font-weight: 600;
  }

  .info-link {
    color: var(--accent-color);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .info-link:hover {
    opacity: 0.85;
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 6px;
  }

  /* Interactive Canvas Section */
  .section-instruction {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin: 0 0 1rem 0;
  }

  .canvas-container {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1rem;
    position: relative;
    width: 100%;
    height: 280px;
    overflow: hidden;
  }

  #graph-canvas {
    width: 100%;
    height: 100%;
    display: block;
    cursor: crosshair;
  }

  /* Cards List details section */
  .cards-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .detail-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
  }

  .detail-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-color);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    background-color: rgba(var(--accent-color-rgb, 129, 199, 132), 0.015);
  }

  /* Glowing visual focus when node hovered */
  .detail-card.highlight-card {
    border-color: var(--accent-color);
    box-shadow: 0 0 15px rgba(129, 199, 132, 0.25);
    background-color: rgba(129, 199, 132, 0.03);
    transform: scale(1.01) translateY(-3px);
  }

  .detail-card.upcoming {
    border-style: dashed;
    opacity: 0.85;
  }

  .card-header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .badge {
    font-size: 0.7rem;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.06em;
  }

  .edu-badge {
    background: rgba(129, 199, 132, 0.12);
    color: var(--accent-color);
    border: 1px solid rgba(129, 199, 132, 0.3);
  }

  .status-badge {
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-secondary);
    border: 1px solid var(--card-border);
  }

  .detail-card.upcoming .status-badge {
    border-color: rgba(156, 163, 175, 0.3);
    color: var(--text-muted);
  }

  .type-badge {
    font-family: var(--font-minecraft);
  }

  .type-badge.education {
    background: rgba(59, 130, 246, 0.12);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .type-badge.project {
    background: rgba(147, 51, 234, 0.12);
    color: #c084fc;
    border: 1px solid rgba(147, 51, 234, 0.3);
  }

  .type-badge.work {
    background: rgba(16, 185, 129, 0.12);
    color: #34d399;
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .type-badge.achievement {
    background: rgba(245, 158, 11, 0.12);
    color: #fbbf24;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .year-badge {
    color: var(--accent-color);
    font-family: var(--font-minecraft);
  }

  .card-heading {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.4rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .heading-icon {
    font-size: 1.25rem;
  }

  .card-subheading {
    font-size: 0.9rem;
    color: var(--accent-color);
    font-weight: 500;
    margin: 0 0 0.5rem 0;
  }

  .card-desc {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .skills-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--card-border);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    color: var(--text-secondary);
  }

  /* Responsive layouts */
  @media (max-width: 900px) {
    .landing-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .sidebar {
      order: -1;
    }
  }

  @media (max-width: 600px) {
    .canvas-container {
      height: 200px;
    }
  }
</style>
