---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About | sawmer.dev">
  <div class="about-container">
    <header class="about-header">
      <h1 class="about-title">About</h1>
      <p class="about-desc">A little bit about me.</p>
    </header>

    <div class="about-content">
      <p>
        Hi! I'm <strong>sawmer</strong>, a backend-focused developer based in Nepal 🇳🇵.
      </p>
      <p>
        I specialize in building modular APIs, reverse-engineering web protocols, automating processes, and managing high-performance databases.
      </p>
      <p>
        This site is my personal space where I showcase my skills, projects, and write about technical challenges I solve.
      </p>
      <p>
        If you'd like to get in touch, feel free to reach out via the contact badges on the home page!
      </p>
    </div>
  </div>
</Layout>

<style>
  .about-container {
    width: 100%;
  }

  .about-header {
    margin-bottom: 2rem;
  }

  .about-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .about-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .about-content {
    color: var(--text-primary);
    line-height: 1.7;
    font-size: 1.05rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-content strong {
    font-weight: 600;
  }
</style>
