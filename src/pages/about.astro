<script>
  function setupTimelineFlow() {
    const container = document.querySelector('.timeline-container');
    const activeLine = document.querySelector('.timeline-line-active');
    const items = document.querySelectorAll('.timeline-item');

    if (!container || !activeLine || !items.length) return;

    items.forEach((item, index) => {
      const card = item.querySelector('.timeline-content-card');
      if (!card) return;

      let rotationTimeout: any = null;

      card.addEventListener('mouseenter', () => {
        const dot = item.querySelector('.timeline-dot');
        if (dot) {
          const containerRect = container.getBoundingClientRect();
          const dotRect = dot.getBoundingClientRect();
          const targetHeight = dotRect.top - containerRect.top + (dotRect.height / 2);
          (activeLine as HTMLElement).style.height = `${targetHeight}px`;
        }

        items.forEach((el, idx) => {
          // active-flow handles line flow and dot glows up to the current card
          if (idx <= index) {
            el.classList.add('active-flow');
          } else {
            el.classList.remove('active-flow');
          }

          // Clear active-branch immediately on enter
          el.classList.remove('active-branch');
        });

        if (rotationTimeout) clearTimeout(rotationTimeout);
        rotationTimeout = setTimeout(() => {
          card.classList.add('start-rotation');
          item.classList.add('active-branch');
        }, 120);
      });

      card.addEventListener('mouseleave', () => {
        (activeLine as HTMLElement).style.height = '0px';
        items.forEach((el) => {
          el.classList.remove('active-flow');
          el.classList.remove('active-branch');
        });

        if (rotationTimeout) {
          clearTimeout(rotationTimeout);
          rotationTimeout = null;
        }
        card.classList.remove('start-rotation');
      });
    });
  }

  setupTimelineFlow();
  document.addEventListener('astro:after-swap', setupTimelineFlow);
</script>
