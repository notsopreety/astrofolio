---
import Layout from '../layouts/Layout.astro';
import LanyardCard from '../components/LanyardCard.astro';

const birthday = new Date("2006-08-11");
const ageDifMs = Date.now() - birthday.getTime();
const ageDate = new Date(ageDifMs);
const age = Math.abs(ageDate.getUTCFullYear() - 1970);

const journey = [
  {
    year: "2020",
    title: "Started Learning Web Development",
    description: "Began my journey into web development with HTML, CSS, and JavaScript fundamentals.",
    type: "education",
    icon: "📖"
  },
  {
    year: "2021",
    title: "First React Project",
    description: "Built my first React application, a task management system with basic CRUD functionality.",
    type: "project",
    icon: "💻"
  },
  {
    year: "2021",
    title: "Learned Node.js & Express",
    description: "Expanded my skills to backend development with Node.js and Express, building RESTful APIs.",
    type: "education",
    icon: "📖"
  },
  {
    year: "2022",
    title: "First Freelance Project",
    description: "Completed my first paid freelance project, an e-commerce website for a local business.",
    type: "work",
    icon: "💼"
  },
  {
    year: "2022",
    title: "MongoDB Certification",
    description: "Earned MongoDB certification, deepening my knowledge of NoSQL database design and optimization.",
    type: "achievement",
    icon: "🏆"
  },
  {
    year: "2023",
    title: "Full-Stack E-Commerce Platform",
    description: "Developed a complete e-commerce platform with user authentication, payment processing, and admin dashboard.",
    type: "project",
    icon: "💻"
  },
  {
    year: "2023",
    title: "Junior Developer Position",
    description: "Secured a position as a Junior MERN Stack Developer at a tech startup, working on innovative web applications.",
    type: "work",
    icon: "💼"
  },
  {
    year: "Present",
    title: "Continuous Learning & Growth",
    description: "Constantly expanding my skills with new technologies and frameworks while building meaningful projects.",
    type: "education",
    icon: "🚀"
  }
];
---

<Layout title="About Me | Samir Badaila" description="Learn more about Samir Badaila, a backend-focused developer from Kathmandu, Nepal. View his timeline, education, and development journey.">
  <div class="landing-grid">
    <div class="main-content">
      <section class="about-section">
        <fieldset class="about-fieldset">
          <legend class="about-legend">About Me</legend>
          
          <div class="bio-text">
            <p>
              I am a passionate MERN stack developer with a strong focus on backend development. My journey in programming began with a curiosity about how web applications work behind the scenes, which led me to specialize in creating efficient, scalable backend solutions. I enjoy solving complex problems, reverse-engineering web systems, and continuously learning new technologies to enhance my skills.
            </p>
          </div>

          <!-- Personal Info Card -->
          <div class="info-card">
            <h3 class="info-card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              Personal Info
            </h3>
            <ul class="info-list">
              <li><span class="info-label">Name:</span> <span class="highlight">Samir Badaila</span></li>
              <li><span class="info-label">Age:</span> <span>{age} years old</span></li>
              <li><span class="info-label">Location:</span> <span>Kathmandu, Nepal</span></li>
              <li><span class="info-label">Email:</span> <a href="mailto:itssamir444@gmail.com" class="info-link">itssamir444@gmail.com</a></li>
            </ul>
          </div>
        </fieldset>
      </section>

      <!-- Education Section -->
      <section class="education-section">
        <fieldset class="about-fieldset">
          <legend class="about-legend">Education</legend>
          
          <div class="education-tree">
            <!-- Center branch lines (visible on desktop) -->
            <div class="tree-canvas-wrapper">
              <svg class="tree-canvas" viewBox="0 0 100 200" fill="none" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Main trunk on the left -->
                <path d="M 20,0 L 20,200" class="tree-path trunk" />
                <!-- Left-to-right branch for Completed Card -->
                <path d="M 20,60 Q 55,60 90,75" class="tree-path branch branch-completed" />
                <!-- Left-to-right branch for Future Card -->
                <path d="M 20,140 Q 55,140 90,155" class="tree-path branch branch-future" />
                
                <!-- Joint dots on the trunk -->
                <circle cx="20" cy="60" r="4" class="tree-dot jointcompleted" />
                <circle cx="20" cy="140" r="4" class="tree-dot jointfuture" />
                
                <!-- End indicators touching the cards on the right -->
                <circle cx="90" cy="75" r="5" class="tree-dot end-completed" />
                <circle cx="90" cy="155" r="5" class="tree-dot end-future" />
              </svg>
            </div>
            
            <div class="tree-cards-container">
              <!-- Completed Card -->
              <div class="education-card completed-node">
                <div class="edu-header">
                  <span class="edu-badge">+2 Computer Science</span>
                  <span class="edu-duration">Completed</span>
                </div>
                <h3 class="edu-title">High School Graduation</h3>
                <p class="edu-faculty">Management Faculty</p>
                <p class="edu-desc">Gained fundamental knowledge in algorithms, database design basics, and programming logic.</p>
              </div>
              
              <div class="tree-space"></div>

              <!-- Future Card -->
              <div class="education-card future-node future">
                <div class="edu-header">
                  <span class="edu-badge">Bachelor's Degree</span>
                  <span class="edu-duration">Upcoming / Planned</span>
                </div>
                <h3 class="edu-title">BSc. (Hons) in Computer Science / IT</h3>
                <p class="edu-desc">Planning to pursue advanced studies to deepen theoretical knowledge in systems engineering, security, and distributed computing architectures.</p>
              </div>
            </div>
          </div>
        </fieldset>
      </section>

      <!-- Journey Timeline Section -->
      <section class="journey-section">
        <fieldset class="about-fieldset">
          <legend class="about-legend">My Journey</legend>
          
          <div class="timeline-container">
            <div class="timeline-line"></div>
            
            <div class="timeline-items">
              {journey.map((item) => (
                <div class="timeline-item">
                  <div class="timeline-badge-container">
                    <div class="timeline-dot"></div>
                    <span class="timeline-icon-box">{item.icon}</span>
                  </div>
                  <div class="timeline-content-card">
                    <div class="timeline-header">
                      <span class={`timeline-type-badge ${item.type}`}>{item.type}</span>
                      <span class="timeline-year">{item.year}</span>
                    </div>
                    <h3 class="timeline-item-title">{item.title}</h3>
                    <p class="timeline-item-desc">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </fieldset>
      </section>
    </div>
    
    <div class="sidebar">
      <div class="sticky-sidebar">
        <LanyardCard />
      </div>
    </div>
  </div>
</Layout>

<style>
  .landing-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .main-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .sidebar {
    position: relative;
  }

  .sticky-sidebar {
    position: sticky;
    top: 3rem;
  }

  /* Outlined Fieldset Styles */
  .about-fieldset {
    background: transparent;
    border: 1.5px solid var(--accent-color);
    border-radius: 16px;
    padding: 1.5rem;
    margin: 0;
    min-inline-size: 0;
    box-sizing: border-box;
  }

  .about-legend {
    font-size: 0.72rem;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--accent-color);
    letter-spacing: 0.08em;
    font-family: var(--font-minecraft);
    padding: 0 0.5rem;
    margin-left: 0.5rem;
    width: auto;
    line-height: 1;
  }

  .bio-text p {
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text-primary);
    margin: 0 0 1.5rem 0;
  }

  /* Education Tree Layout */
  .education-tree {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    position: relative;
  }

  .tree-canvas-wrapper {
    display: none; /* Hide on mobile/stacked layouts by default */
  }

  @media (min-width: 768px) {
    .education-tree {
      grid-template-columns: 120px 1fr;
      gap: 0;
    }

    .tree-canvas-wrapper {
      display: block;
      grid-column: 1;
      height: 380px;
      position: relative;
    }

    .tree-canvas {
      width: 100%;
      height: 100%;
    }

    .tree-path {
      stroke-width: 3px;
      stroke-linecap: round;
    }

    .tree-path.trunk {
      stroke: var(--card-border);
    }

    .tree-path.branch-completed {
      stroke: var(--accent-color);
      filter: drop-shadow(0 0 4px rgba(129, 199, 132, 0.4));
    }

    .tree-path.branch-future {
      stroke: var(--text-muted);
      stroke-dasharray: 4px;
    }

    .tree-dot {
      stroke-width: 3px;
      fill: var(--bg-color);
    }

    .tree-dot.jointcompleted {
      stroke: var(--accent-color);
      fill: var(--accent-color);
    }

    .tree-dot.jointfuture {
      stroke: var(--text-muted);
      fill: var(--text-muted);
    }

    .tree-dot.end-completed {
      stroke: var(--accent-color);
      fill: var(--bg-color);
    }

    .tree-dot.end-future {
      stroke: var(--text-muted);
      fill: var(--bg-color);
    }

    .tree-cards-container {
      grid-column: 2;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 380px;
      padding: 1rem 0;
    }

    .tree-space {
      height: 40px;
    }
  }

  .education-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .education-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    background: linear-gradient(145deg, var(--card-bg), rgba(129, 199, 132, 0.02));
  }

  .education-card.future {
    border-style: dashed;
    opacity: 0.85;
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    margin-bottom: 0.25rem;
  }

  .edu-badge {
    background: rgba(168, 185, 204, 0.1);
    color: var(--accent-color);
    border: 1.5px solid var(--accent-color);
    font-family: var(--font-minecraft);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .education-card.future .edu-badge {
    background: rgba(156, 163, 175, 0.1);
    color: var(--text-secondary);
    border-color: var(--text-secondary);
  }

  .edu-duration {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .edu-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .edu-faculty {
    font-size: 0.88rem;
    color: var(--accent-color);
    font-weight: 500;
    margin: 0;
  }

  .edu-desc {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
  }

  .info-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .info-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    background: linear-gradient(145deg, var(--card-bg), rgba(129, 199, 132, 0.02));
  }

  .info-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-color);
    font-family: var(--font-minecraft);
    text-transform: uppercase;
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card-icon {
    color: var(--accent-color);
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.92rem;
  }

  .info-list li {
    display: flex;
    justify-content: space-between;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .info-label {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .highlight {
    color: var(--accent-color);
    font-weight: 600;
  }

  .info-link {
    color: var(--accent-color);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .info-link:hover {
    opacity: 0.85;
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 6px;
  }

  /* Timeline / Journey styles */
  .timeline-container {
    position: relative;
    padding-left: 2rem;
    margin-top: 0.5rem;
  }

  .timeline-line {
    position: absolute;
    left: 7px;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: var(--card-border);
  }

  .timeline-items {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-item {
    position: relative;
  }

  .timeline-badge-container {
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    display: flex;
    align-items: center;
  }

  .timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg-color);
    border: 3px solid var(--accent-color);
    z-index: 2;
    box-shadow: 0 0 0 3px rgba(129, 199, 132, 0.15), 0 0 10px rgba(129, 199, 132, 0.4);
  }

  .timeline-icon-box {
    display: none; /* Can be enabled for large screen badges */
  }

  .timeline-content-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.25rem;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .timeline-content-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    background: linear-gradient(145deg, var(--card-bg), rgba(129, 199, 132, 0.02));
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.6rem;
  }

  .timeline-year {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-color);
    font-family: var(--font-minecraft);
  }

  .timeline-type-badge {
    font-size: 0.68rem;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .timeline-type-badge.education {
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .timeline-type-badge.project {
    background: rgba(147, 51, 234, 0.15);
    color: #c084fc;
    border: 1px solid rgba(147, 51, 234, 0.3);
  }

  .timeline-type-badge.work {
    background: rgba(16, 185, 129, 0.15);
    color: #34d399;
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .timeline-type-badge.achievement {
    background: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .timeline-item-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.5rem 0;
  }

  .timeline-item-desc {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Responsive styling */
  @media (max-width: 900px) {
    .landing-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .sidebar {
      order: -1; /* Sidebar with Lanyard Card moves to top on mobile */
    }
  }


</style>
