---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);

// Simple slugify function
function slugify(text: string) {
  return text
    .toString()
    .toLowerCase()
    .trim()
    .replace(/\s+/g, '-')
    .replace(/[^\w\-]+/g, '')
    .replace(/\-\-+/g, '-');
}

// Get unique tags and count how many posts use them
const tagCounts = new Map<string, { name: string; count: number }>();
posts.forEach(post => {
  if (post.data.tags) {
    post.data.tags.forEach(tag => {
      const slug = slugify(tag);
      const existing = tagCounts.get(slug);
      if (existing) {
        existing.count += 1;
      } else {
        tagCounts.set(slug, { name: tag, count: 1 });
      }
    });
  }
});

const sortedTags = Array.from(tagCounts.entries())
  .map(([slug, info]) => ({ slug, ...info }))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<Layout title="Tags | samirb.com.np">
  <div class="blog-container">
    <div class="breadcrumb" transition:name="posts-breadcrumb">
      <a href="/">Home</a>
      <span class="separator">&raquo;</span>
      <span>Tags</span>
    </div>
    <header class="blog-header">
      <h1 class="blog-title" transition:name="posts-title">Tags</h1>
      <p class="blog-desc" transition:name="posts-desc">All the tags used in posts.</p>
    </header>

    <ul class="tags-list">
      {sortedTags.map(tag => (
        <li class="tag-item">
          <a href={`/tags/${tag.slug}/`} class="tag-link">
            <span class="tag-hash">#</span>
            <span class="tag-name" transition:name={`tag-${tag.slug}`}>{tag.name}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .blog-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    min-height: 50vh;
  }

  .blog-header {
    margin-bottom: 2.5rem;
  }

  .blog-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .blog-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 1.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tag-item {
    margin: 0;
  }

  .tag-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 1.15rem;
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 6px;
    transition: color 0.2s;
  }

  .tag-link:hover {
    color: var(--accent-color);
  }

  .tag-hash {
    opacity: 0.8;
  }

  .tag-name {
    font-weight: 500;
  }
</style>
