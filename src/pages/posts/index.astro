---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
// Sort by date descending
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<Layout title="Posts | samirb.com.np">
  <div class="blog-container">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="separator">&raquo;</span>
      <span>Posts</span>
    </div>
    <header class="blog-header">
      <h1 class="blog-title">Posts</h1>
      <p class="blog-desc">All the articles I've posted.</p>
    </header>

    <ul class="posts-list">
      {sortedPosts.map((post) => (
        <li class="post-item">
          <a href={`/posts/${post.id}`} class="post-title-link">
            <h2 class="post-title" transition:name={post.id}>{post.data.title}</h2>
          </a>
          <div class="post-meta">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="calendar-icon">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <time datetime={post.data.pubDatetime.toISOString()}>
              {formatDate(post.data.pubDatetime)}
            </time>
          </div>
          <p class="post-desc">{post.data.description}</p>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .blog-container {
    width: 100%;
  }

  .blog-header {
    margin-bottom: 2rem;
  }

  .blog-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .blog-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    margin-bottom: 2.5rem;
  }

  .post-title-link {
    display: inline-block;
    color: var(--accent-color);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .post-title-link:hover {
    opacity: 0.85;
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 6px;
  }

  .post-title {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-family: var(--font-mono);
    margin: 0.4rem 0 0.6rem 0;
  }

  .calendar-icon {
    opacity: 0.8;
  }

  .post-desc {
    color: var(--text-secondary);
    line-height: 1.5;
  }
</style>
