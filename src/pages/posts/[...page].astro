---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  // Sort by date descending
  const sortedPosts = posts.sort(
    (a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf()
  );
  return paginate(sortedPosts, { pageSize: 4 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<Layout title={`Posts - Page ${page.currentPage} | samirb.com.np`}>
  <div class="blog-container">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="separator">&raquo;</span>
      {page.currentPage > 1 ? (
        <a href="/posts">Posts</a>
        <span class="separator">&raquo;</span>
        <span>Page {page.currentPage}</span>
      ) : (
        <span>Posts</span>
      )}
    </div>
    <header class="blog-header">
      <h1 class="blog-title">Posts</h1>
      <p class="blog-desc">All the articles I've posted.</p>
    </header>

    <ul class="posts-list">
      {page.data.map((post) => (
        <li class="post-item">
          <a href={`/posts/${post.id}`} class="post-title-link">
            <h2 class="post-title" transition:name={post.id}>{post.data.title}</h2>
          </a>
          <div class="post-meta">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="calendar-icon">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <time datetime={post.data.pubDatetime.toISOString()}>
              {formatDate(post.data.pubDatetime)}
            </time>
          </div>
          <p class="post-desc">{post.data.description}</p>
        </li>
      ))}
    </ul>

    {page.lastPage > 1 && (
      <nav class="pagination-nav" role="navigation" aria-label="Pagination Navigation">
        {page.url.prev ? (
          <a href={page.url.prev} class="pagination-btn" aria-label="Go to Previous Page">
            <svg xmlns="http://www.w3.org/2000/svg" class="arrow-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span>Prev</span>
          </a>
        ) : (
          <span class="pagination-btn disabled" aria-disabled="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="arrow-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span>Prev</span>
          </span>
        )}

        <span class="page-indicator">
          {page.currentPage} / {page.lastPage}
        </span>

        {page.url.next ? (
          <a href={page.url.next} class="pagination-btn" aria-label="Go to Next Page">
            <span>Next</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="arrow-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        ) : (
          <span class="pagination-btn disabled" aria-disabled="true">
            <span>Next</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="arrow-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        )}
      </nav>
    )}
  </div>
</Layout>

<style>
  .blog-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    min-height: 50vh;
  }

  .blog-header {
    margin-bottom: 2rem;
  }

  .blog-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .blog-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
    flex-grow: 1;
  }

  .post-item {
    margin-bottom: 2.5rem;
  }

  .post-title-link {
    display: inline-block;
    color: var(--accent-color);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .post-title-link:hover {
    opacity: 0.85;
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 6px;
  }

  .post-title {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-family: var(--font-mono);
    margin: 0.4rem 0 0.6rem 0;
  }

  .calendar-icon {
    opacity: 0.8;
  }

  .post-desc {
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* Pagination styles */
  .pagination-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 3rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    user-select: none;
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    opacity: 0.85;
    transition: opacity 0.2s, transform 0.2s;
  }

  .pagination-btn:not(.disabled):hover {
    opacity: 1;
    color: var(--accent-color);
  }

  .pagination-btn.disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  .arrow-icon {
    width: 1.15rem;
    height: 1.15rem;
  }

  .page-indicator {
    color: var(--text-primary);
    font-weight: 500;
  }
</style>
