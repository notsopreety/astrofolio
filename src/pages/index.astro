---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import LanyardCard from '../components/LanyardCard.astro';
import Skills from '../components/Skills.astro';
import Connect from '../components/Connect.astro';
---

<Layout>
	<div class="landing-grid">
		<div class="main-content">
			<Hero />
			<Skills />
			<Connect />
		</div>
		<div class="sidebar">
			<div class="sticky-sidebar">
				<LanyardCard />
			</div>
		</div>
	</div>
</Layout>

<style>
	.landing-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 3rem;
		align-items: start;
	}

	.landing-grid.no-sidebar {
		grid-template-columns: 1fr;
		max-width: 680px;
		margin: 0 auto;
	}

	.main-content {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.sidebar {
		position: relative;
	}

	.sticky-sidebar {
		position: sticky;
		top: 3rem;
	}

	@media (max-width: 900px) {
		.landing-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.sticky-sidebar {
			position: static;
		}
	}
</style>
